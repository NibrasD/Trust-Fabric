# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string
SUPABASE_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# Or standard PostgreSQL URL (used as fallback):
DATABASE_URL=postgresql://localhost:5432/trust_fabric

# ─── Sessions ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ─── Stellar Accounts (secret keys) ──────────────────────────────────────────
